# ClawShield Production Secrets
# Copy to .env and fill in values. Never commit .env to git.

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
GATEWAY_AUTH_TOKEN=GENERATED_AT_DEPLOY_TIME
STUDIO_ACCESS_TOKEN=GENERATED_AT_DEPLOY_TIME
# ClawShield uses STUDIO_ACCESS_TOKEN as HMAC signing key for deep-link tickets.
# Set CLAWSHIELD_STUDIO_TOKEN to the same value as STUDIO_ACCESS_TOKEN.
CLAWSHIELD_STUDIO_TOKEN=${STUDIO_ACCESS_TOKEN}

# Demo stack — separate secrets from private stack
DEMO_GATEWAY_TOKEN=GENERATED_AT_DEPLOY_TIME
DEMO_STUDIO_TOKEN=GENERATED_AT_DEPLOY_TIME
